  <style>
  .mcc-tabs { border-bottom: none; }
  .mcc-tab-btn { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.09); color: rgba(247,243,236,.5); font-size: .62rem; font-weight: 600; letter-spacing: .05em; padding: .45rem 1rem; border-radius: 8px; cursor: pointer; transition: all .2s; backdrop-filter:blur(8px); }
  .mcc-tab-btn:hover { background: rgba(255,255,255,.09); color: rgba(247,243,236,.9); border-color:rgba(255,255,255,.18); }
  .mcc-tab-btn.mcc-active { background: linear-gradient(135deg,#1d4ed8,#0d9488); border-color: transparent; color: #fff; box-shadow: 0 0 20px rgba(59,130,246,.45), 0 0 40px rgba(6,182,212,.15); transform: translateY(-1px); }
  .mcc-frame { border-radius: 12px; overflow: hidden; box-shadow: 0 40px 100px rgba(0,0,0,.7), 0 0 0 1px rgba(59,130,246,.2), 0 0 40px rgba(59,130,246,.08); border: 1px solid rgba(59,130,246,.25); position:relative; animation: mcc-frame-glow 4s ease-in-out infinite; }
  @keyframes orb-drift-a { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(-40px,30px) scale(1.05); } }
  @keyframes orb-drift-b { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(30px,-40px) scale(1.08); } }
  @keyframes mcc-frame-glow { 0%,100% { box-shadow: 0 40px 100px rgba(0,0,0,.7), 0 0 0 1px rgba(59,130,246,.2), 0 0 40px rgba(59,130,246,.08); } 50% { box-shadow: 0 40px 100px rgba(0,0,0,.7), 0 0 0 1px rgba(6,182,212,.35), 0 0 60px rgba(6,182,212,.14); } }
  @keyframes mcc-pulse { 0%,100% { opacity:1; transform:scale(1); } 50% { opacity:.6; transform:scale(1.3); } }
  .mcc-chrome-bar { background: #111827; padding: .55rem 1rem; display: flex; align-items: center; gap: .5rem; border-bottom: 1px solid rgba(255,255,255,.06); border-top: 2px solid transparent; border-image: linear-gradient(90deg,#96B252,#3b82f6,#06b6d4) 1; }
  .mcc-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }
  .mcc-url-pill { background: rgba(255,255,255,.06); color: rgba(255,255,255,.35); font-size: .55rem; padding: .22rem .85rem; border-radius: 20px; margin-left: .75rem; flex: 1; max-width: 280px; border: 1px solid rgba(255,255,255,.07); letter-spacing:.02em; }
  .mcc-screen { display: flex; min-height: 420px; }
  .mcc-hidden { display: none !important; }
  .mcc-sidebar { width: 160px; min-width: 160px; background: linear-gradient(180deg,#0d1526 0%,#0a1020 100%); padding: .75rem .6rem; display: flex; flex-direction: column; gap: .15rem; border-right: 1px solid rgba(59,130,246,.12); }
  .mcc-logo-block { display: flex; align-items: center; gap: .4rem; margin-bottom: .75rem; }
  .mcc-logo-icon { width: 26px; height: 26px; background: linear-gradient(135deg, #2563eb, #06b6d4); border-radius: 7px; flex-shrink: 0; box-shadow: 0 0 12px rgba(6,182,212,.35); display:flex;align-items:center;justify-content:center; }
  .mcc-nav-group-label { font-size: .45rem; font-weight: 700; color: #475569; letter-spacing: .12em; text-transform: uppercase; padding: .5rem 0 .2rem .4rem; }
  .mcc-nav-item { font-size: .6rem; color: #94a3b8; padding: .3rem .5rem; border-radius: 5px; cursor: pointer; display: flex; align-items: center; gap: .35rem; }
  .mcc-nav-icon { font-size: .55rem; }
  .mcc-nav-active { background: rgba(59,130,246,.15); color: #93c5fd; font-weight: 600; border-left: 2px solid #3b82f6; margin-left: -2px; border-radius: 0 5px 5px 0; }
  .mcc-main-area { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
  .mcc-top-bar { background: linear-gradient(135deg, #1a2f6b 0%, #1d4ed8 60%, #0e7490 100%); padding: .85rem 1.25rem; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(255,255,255,.08); }
  .mcc-sparkle { width: 28px; height: 28px; background: rgba(255,255,255,.15); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: .8rem; color: #60efff; flex-shrink: 0; }
  .mcc-report-btn { background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.2); color: rgba(255,255,255,.8); font-size: .55rem; padding: .3rem .7rem; border-radius: 6px; cursor: pointer; }
  .mcc-stat-grid { display: flex; gap: .5rem; padding: .75rem 1rem; background: #f8fafc; }
  .mcc-stat-card { flex: 1; background: rgba(255,255,255,.97); border: 1px solid rgba(226,232,240,.8); border-radius: 10px; padding: .6rem .75rem; min-width: 0; box-shadow: 0 2px 8px rgba(0,0,0,.06); }
  .mcc-stat-label { font-size: .45rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; margin-bottom: .2rem; }
  .mcc-stat-num { font-size: 1.4rem; font-weight: 800; line-height: 1; margin-bottom: .15rem; }
  .mcc-stat-sub { font-size: .5rem; color: #64748b; margin-bottom: .35rem; }
  .mcc-stat-bar { height: 2px; background: #e2e8f0; border-radius: 1px; }
  .mcc-stat-bar div { height: 100%; border-radius: 1px; }
  .mcc-panel { background: #fff; margin: .5rem 1rem; border-radius: 12px; border: 1px solid rgba(226,232,240,.7); padding: .75rem 1rem; box-shadow: 0 1px 6px rgba(0,0,0,.05); }
  .mcc-panel-header { display: flex; align-items: center; gap: .75rem; margin-bottom: .5rem; font-size: .65rem; }
  .mcc-view-all { margin-left: auto; font-size: .55rem; color: #3b82f6; cursor: pointer; }
  .mcc-badge { font-size: .5rem; font-weight: 600; padding: .15rem .4rem; border-radius: 10px; }
  .mcc-badge-gray { background: #f1f5f9; color: #64748b; }
  .mcc-badge-blue { background: #dbeafe; color: #1d4ed8; }
  .mcc-badge-green { background: #dcfce7; color: #15803d; }
  .mcc-badge-purple { background: #ede9fe; color: #7c3aed; }
  .mcc-campaign-row { display: flex; align-items: center; justify-content: space-between; padding: .4rem 0; border-bottom: 1px solid #f1f5f9; font-size: .6rem; color: #1e293b; gap: 1rem; }
  .mcc-prog-wrap { width: 120px; min-width: 80px; height: 3px; background: #e2e8f0; border-radius: 2px; flex-shrink: 0; }
  .mcc-prog-bar { height: 100%; border-radius: 2px; }
  .mcc-donut-card { background: #fff; border: 1px solid rgba(226,232,240,.8); border-radius: 12px; padding: .6rem .75rem; display: flex; flex-direction: column; align-items: center; gap: .3rem; box-shadow: 0 1px 6px rgba(0,0,0,.05); }
  .mcc-donut-label { font-size: .45rem; font-weight: 700; color: #64748b; letter-spacing: .08em; text-transform: uppercase; }
  .mcc-camp-card { background: #fff; border: 1px solid rgba(226,232,240,.8); border-radius: 12px; padding: .75rem; min-width: 160px; max-width: 185px; flex-shrink: 0; box-shadow: 0 2px 10px rgba(0,0,0,.06); }
  .mcc-camp-status { font-size: .5rem; color: #15803d; background: #dcfce7; padding: .1rem .4rem; border-radius: 10px; display: inline-block; margin-bottom: .4rem; }
  .mcc-camp-name { font-size: .65rem; font-weight: 700; color: #1e293b; line-height: 1.3; margin-bottom: .4rem; }
  .mcc-view-toggle { background: #f1f5f9; border: 1px solid #e2e8f0; color: #64748b; font-size: .55rem; padding: .2rem .5rem; border-radius: 5px; cursor: pointer; }
  .mcc-vt-active { background: #1e293b; color: #fff; border-color: #1e293b; }
  .mcc-cal-grid { display: grid; grid-template-columns: repeat(5,1fr); gap: 0; border-top: 1px solid #e2e8f0; flex: 1; }
  .mcc-cal-head { font-size: .5rem; font-weight: 700; color: #64748b; letter-spacing: .08em; text-align: center; padding: .35rem 0; background: #f8fafc; border-right: 1px solid #e2e8f0; border-bottom: 1px solid #e2e8f0; }
  .mcc-cal-cell { border-right: 1px solid #e2e8f0; border-bottom: 1px solid #e2e8f0; padding: .3rem .35rem; min-height: 52px; display: flex; flex-direction: column; gap: .15rem; }
  .mcc-cal-date { font-size: .5rem; color: #94a3b8; margin-bottom: .1rem; }
  .mcc-cal-evt { font-size: .42rem; color: #fff; border-radius: 2px; padding: .08rem .25rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .mcc-nav-arrow { background: none; border: 1px solid #e2e8f0; color: #64748b; font-size: .6rem; padding: .2rem .5rem; border-radius: 5px; cursor: pointer; }
  .mcc-truepro-panel { position: absolute; right: 12px; top: 0; bottom: 0; width: 280px; background: #1e293b; border-left: 1px solid #334155; display: flex; flex-direction: column; }
  .mcc-tp-card { background: rgba(15,23,42,.9); border: 1px solid rgba(6,182,212,.25); border-radius: 14px; width: 100%; max-width: 320px; display: flex; flex-direction: column; backdrop-filter: blur(12px); box-shadow: 0 0 40px rgba(6,182,212,.12), 0 20px 60px rgba(0,0,0,.5); }
  .mcc-tp-avatar-lg { width: 34px; height: 34px; background: linear-gradient(135deg,#06b6d4,#3b82f6); border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: 0 0 12px rgba(6,182,212,.4); }
  .mcc-tp-orb { width: 80px; height: 80px; display: flex; align-items: center; justify-content: center; background: radial-gradient(circle, rgba(6,182,212,.2) 0%, transparent 70%); border-radius: 50%; animation: mcc-orb-pulse 3s ease-in-out infinite; }
  @keyframes mcc-orb-pulse { 0%,100% { box-shadow: 0 0 0 0 rgba(6,182,212,.2); } 50% { box-shadow: 0 0 0 16px rgba(6,182,212,.0); } }
  .mcc-tp-prompt-lg { width: 100%; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.08); color: rgba(255,255,255,.75); font-size: .6rem; padding: .45rem .75rem; border-radius: 8px; cursor: pointer; text-align: left; transition: all .2s; }
  .mcc-tp-prompt-lg:hover { background: rgba(6,182,212,.1); border-color: rgba(6,182,212,.3); }
  .mcc-tp-header { display: flex; justify-content: space-between; align-items: center; padding: .75rem 1rem; border-bottom: 1px solid #334155; }
  .mcc-tp-avatar { width: 28px; height: 28px; background: linear-gradient(135deg,#06b6d4,#3b82f6); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: .8rem; }
  .mcc-tp-bot-icon { width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; }
  .mcc-tp-prompt { width: 100%; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); color: rgba(255,255,255,.7); font-size: .6rem; padding: .5rem .75rem; border-radius: 6px; cursor: pointer; text-align: left; }
  .mcc-tp-input-row { padding: .6rem .75rem; border-top: 1px solid #334155; display: flex; gap: .5rem; margin-top: auto; }
  .mcc-tp-input { flex: 1; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); color: #fff; font-size: .6rem; padding: .4rem .6rem; border-radius: 6px; }
  .mcc-tp-send { background: #0d9488; border: none; color: #fff; font-size: .65rem; width: 28px; height: 28px; border-radius: 6px; cursor: pointer; }
  .mcc-tp-pill { position: absolute; bottom: -36px; right: 0; background: linear-gradient(90deg,#0d9488,#06b6d4); color: #fff; font-size: .6rem; font-weight: 700; padding: .35rem 1rem; border-radius: 20px; white-space: nowrap; }
  .mcc-strat-tab { font-size: .55rem; font-weight: 600; padding: .5rem .75rem; color: #64748b; cursor: pointer; border-bottom: 2px solid transparent; }
  .mcc-strat-active { color: #3b82f6; border-bottom-color: #3b82f6; }
  .mcc-commitment { display: flex; align-items: flex-start; gap: .5rem; padding: .45rem 0; border-bottom: 1px solid rgba(255,255,255,.06); font-size: .65rem; color: #e2e8f0; line-height: 1.4; }
  .mcc-commit-num { background: #0d9488; color: #fff; font-size: .45rem; font-weight: 800; width: 16px; height: 16px; border-radius: 3px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: .05rem; }
  .mcc-why-card { flex: 1; background: #fff; border: 1px solid #e2e8f0; border-radius: 8px; padding: .75rem; text-align: center; }
  .mcc-lead-stat { flex: 1; background: #fff; border: 1px solid #e2e8f0; border-radius: 10px; padding: .5rem .65rem; min-width: 0; box-shadow: 0 1px 4px rgba(0,0,0,.05); }
  .mcc-lead-stat-label { font-size: .44rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; margin-bottom: .15rem; }
  .mcc-lead-stat-num { font-size: 1.3rem; font-weight: 800; line-height: 1; margin-bottom: .1rem; color: #1e293b; }
  .mcc-lead-stat-sub { font-size: .45rem; color: #64748b; line-height: 1.3; }
  .mcc-leads-table { width: 100%; border-collapse: collapse; font-size: .6rem; }
  .mcc-leads-table th { font-size: .45rem; font-weight: 700; color: #94a3b8; letter-spacing: .08em; text-align: left; padding: .35rem .5rem; border-bottom: 1px solid #e2e8f0; }
  .mcc-leads-table td { padding: .45rem .5rem; border-bottom: 1px solid #f1f5f9; color: #1e293b; vertical-align: middle; }
  .mcc-leads-table tr:hover td { background: #f8fafc; }
  .mcc-src-badge { font-size: .45rem; background: #dbeafe; color: #1d4ed8; padding: .1rem .4rem; border-radius: 10px; white-space: nowrap; }
  .mcc-stage-badge { font-size: .45rem; padding: .12rem .4rem; border-radius: 10px; font-weight: 600; white-space: nowrap; }
  .mcc-stage-sql { background: #fef9c3; color: #854d0e; }
  .mcc-stage-mql { background: #dbeafe; color: #1d4ed8; }
  .mcc-stage-mal { background: #f0fdf4; color: #15803d; }
  .mcc-stage-customer { background: #dcfce7; color: #15803d; }
  </style>

  <script>
  function mccSwitch(btn, screenId) {
    document.querySelectorAll('.mcc-tab-btn').forEach(b => b.classList.remove('mcc-active'));
    btn.classList.add('mcc-active');
    document.querySelectorAll('.mcc-screen').forEach(s => { s.classList.add('mcc-hidden'); s.style.display = 'none'; });
    var screen = document.getElementById(screenId);
    screen.classList.remove('mcc-hidden');
    screen.style.display = 'flex';
    var urls = { 'mcc-s-dashboard': 'mcc.internal / dashboard', 'mcc-s-campaigns': 'mcc.internal / campaigns', 'mcc-s-calendar': 'mcc.internal / calendar', 'mcc-s-truepro': 'mcc.internal / live-intelligence', 'mcc-s-strategy': 'mcc.internal / agentic-strategy', 'mcc-s-leads': 'mcc.internal / leads' };
    document.getElementById('mcc-url-display').textContent = urls[screenId] || 'mcc.internal';
  }
  </script>



  <!-- WHAT MAKES IT DIFFERENT -->
  <section class="section section--white">
    <div class="section-inner">
      <div class="s-label">What Makes It Different</div>
      <h2 class="section-title fade-in">Not another AI tool.<br>A connected system.</h2>
      <div class="why-grid">
        <div class="fade-in">
          <div class="differentiator" style="background: var(--surface); border-left-color: var(--accent);">
            <h4>It connects the entire workflow</h4>
            <p>Unlike most AI tools that solve one problem at a time, this system connects campaign planning, content creation, performance reporting, and sales alignment into one coherent workspace.</p>
          </div>
          <div class="differentiator" style="background: var(--surface); border-left-color: var(--accent);">
            <h4>It&rsquo;s built for marketers, not developers</h4>
            <p>No code required. No IT dependency. The system is designed to be owned and operated by the marketing team, which means it actually gets used.</p>
          </div>
          <div class="differentiator" style="background: var(--surface); border-left-color: var(--accent);">
            <h4>It learns the business</h4>
            <p>Over time, the system builds a knowledge base of campaigns, results, messaging, and audience insights, so every new initiative benefits from everything that came before it.</p>
          </div>
        </div>
        <div class="fade-in delay-1">
          <div class="differentiator" style="background: var(--surface); border-left-color: var(--accent);">
            <h4>It reduces coordination overhead</h4>
            <p>Campaign updates, reporting, content briefs, and performance summaries that used to take hours now happen automatically, freeing the team to focus on strategy and creativity.</p>
          </div>
          <div class="differentiator" style="background: var(--surface); border-left-color: var(--accent);">
            <h4>It makes AI a collaborator, not a shortcut</h4>
            <p>The goal isn&rsquo;t to use AI to produce more content faster. It&rsquo;s to use AI to think more clearly, plan more strategically, and execute with more precision.</p>
          </div>
          <div class="differentiator" style="background: var(--surface); border-left-color: var(--accent);">
            <h4>It&rsquo;s already producing results</h4>
            <p>AI-powered workflows implemented at Syspro improved planning, reporting, content development, and campaign execution, contributing to measurable pipeline growth across the Americas.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY IT MATTERS -->
  <section class="section section--dark">
    <div class="section-inner">
      <div class="s-label">Why It Matters</div>
      <h2 class="section-title fade-in" style="margin-bottom: 2rem;">The future of<br>marketing is already here.<br><span style="background:linear-gradient(90deg,#3B82F6,#06B6D4,#84CC16);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Most teams aren&rsquo;t in it.</span></h2>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;" class="fade-in delay-1">
        <div>
          <p class="body-text" style="margin-bottom: 1.5rem;">Marketing teams that use AI strategically, not just for writing, will move faster, make better decisions, and focus more of their time on the work that actually moves the business forward.</p>
          <p class="body-text" style="margin-bottom: 1.5rem;">The gap between teams that will use AI well and those that won&rsquo;t is widening fast. The tools exist. The question is whether you&rsquo;re building a system around them or just using them one prompt at a time.</p>
        </div>
        <div>
          <p class="body-text" style="margin-bottom: 1.5rem;">This project is my answer to that question. It&rsquo;s not a side project or an experiment. It&rsquo;s a new way of running marketing that I&rsquo;ve been building, testing, and using in practice at Syspro.</p>
          <p class="body-text">The next version of high-performing marketing isn&rsquo;t faster execution. It&rsquo;s smarter execution, with systems that learn, adapt, and compound over time.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- AI STATS -->
  <div class="stats-bar">
    <div class="stats-grid" style="max-width: 1240px; margin: 0 auto;">
      <div class="stat fade-in">
        <span class="stat-number">$15.5M+</span>
        <span class="stat-label">Marketing-Sourced Pipeline</span>
      </div>
      <div class="stat fade-in delay-1">
        <span class="stat-number">$6M+</span>
        <span class="stat-label">Closed-Won Revenue Influenced</span>
      </div>
      <div class="stat fade-in delay-2">
        <span class="stat-number">8</span>
        <span class="stat-label">Integrated Modules in the Command Center</span>
      </div>
      <div class="stat fade-in delay-3">
        <span class="stat-number">1</span>
        <span class="stat-label">Connected Workspace. Zero Code Required.</span>
      </div>
    </div>
  </div>


  <!-- TESTIMONIALS -->
  <section class="testimonial-section">
    <div class="testimonial-carousel">
      <div class="s-label">What Others Say</div>
      <div class="testimonial-track">
        <div class="testimonial-slide">
          <span class="t-mark">&ldquo;</span>
          <p class="t-quote">Jessica is one of the hardest working people I&rsquo;ve worked with. She&rsquo;s able to manage complex, fast-moving work with precision and always delivers with real impact. She stays ahead of the curve on tools and AI, which made our team faster and more effective without sacrificing quality.</p>
          <div class="t-name">Pat Bolin</div>
          <div class="t-role">GTM and Lead Qualification &middot; Syspro</div>
        </div>
      </div>
    </div>
  </section>
  <!-- CLOSING QUOTE -->
  <section class="section section--mid">
    <div class="section-inner">
      <div class="pull-quote fade-in">
        AI doesn&rsquo;t replace the marketer. It amplifies the marketer who knows how to use it.
      </div>
    </div>
  </section>

  <!-- PAGE NAV STRIP -->
  <section class="section section--dark" style="padding: 3rem 2rem;">
    <div class="section-inner" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
      <div style="font-size: .62rem; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; color: rgba(247,243,236,.3);">Continue Exploring</div>
      <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <a href="landing-pages.html" class="btn btn--ghost">&larr; Landing Pages</a>
        <a href="index.html" class="btn btn--ghost">Back to Home &rarr;</a>
      </div>
    </div>
  </section>

  <script>
    const toggle = document.getElementById('navToggle');
    const mobile = document.getElementById('navMobile');
    toggle.addEventListener('click', () => mobile.classList.toggle('open'));
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-in').forEach(el => obs.observe(el));
  </script>
  <script src="scripts.js"></script>
</body>
</html>
