<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="AI Marketing Command Center: Jessica Rudnicki. Building the future of marketing operations through AI-powered workflows, automation, and intelligent systems.">
  <title>AI Innovation | Jessica Rudnicki</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="styles.css">
  <style>
    /* AI page accent overrides */
    .ai-tag {
      display: inline-block;
      font-size: .55rem;
      font-weight: 700;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--accent);
      border: 1px solid rgba(150,178,82,.4);
      padding: .25rem .6rem;
      margin-bottom: 1rem;
    }
    .ai-stat {
      padding: 1.75rem;
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.07);
      text-align: center;
    }
    .ai-stat-num {
      font-family: var(--display);
      font-size: 2.5rem;
      color: var(--accent);
      line-height: 1;
      display: block;
      margin-bottom: .35rem;
    }
    .ai-stat-label {
      font-size: .72rem;
      color: rgba(247,243,236,.5);
      letter-spacing: .06em;
      line-height: 1.4;
    }
    .why-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      margin-top: 3rem;
      align-items: start;
    }
    .differentiator {
      padding: 2rem;
      border-left: 2px solid var(--accent);
      margin-bottom: 1.5rem;
      background: rgba(255,255,255,.03);
    }
    .differentiator h4 {
      font-family: var(--display);
      font-size: 1.1rem;
      letter-spacing: .04em;
      color: var(--black);
      margin-bottom: .5rem;
    }
    .differentiator p {
      font-size: .85rem;
      color: rgba(12,12,14,.62);
      line-height: 1.65;
    }
    @media (max-width: 720px) {
      .why-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    }

    /* === AI PAGE GRADIENT THEME: blue → teal → lime === */
    .nav-links a.active,
    .nav-mobile a.active {
      background: linear-gradient(90deg, #3B82F6, #06B6D4, #84CC16) !important;
      -webkit-background-clip: text !important;
      -webkit-text-fill-color: transparent !important;
      background-clip: text !important;
    }
    .page-hero .ph-label {
      background: linear-gradient(90deg, #3B82F6, #06B6D4, #84CC16) !important;
      -webkit-background-clip: text !important;
      -webkit-text-fill-color: transparent !important;
      background-clip: text !important;
      border-left-color: #3B82F6 !important;
    }
    .s-label {
      background: linear-gradient(90deg, #3B82F6, #06B6D4, #84CC16) !important;
      -webkit-background-clip: text !important;
      -webkit-text-fill-color: transparent !important;
      background-clip: text !important;
    }
    .s-label::before {
      background: linear-gradient(90deg, #3B82F6, #06B6D4, #84CC16) !important;
    }
    .ai-tag {
      background: linear-gradient(90deg, #3B82F6, #06B6D4, #84CC16) !important;
      -webkit-background-clip: text !important;
      -webkit-text-fill-color: transparent !important;
      background-clip: text !important;
      border-color: rgba(59,130,246,.4) !important;
    }
    .ai-stat-num {
      background: linear-gradient(90deg, #3B82F6, #06B6D4, #84CC16) !important;
      -webkit-background-clip: text !important;
      -webkit-text-fill-color: transparent !important;
      background-clip: text !important;
    }
    .differentiator {
      border-left-color: #3B82F6 !important;
    }
    .stats-bar {
      background: linear-gradient(135deg, #0a1628 0%, #0d2855 40%, #0a3d4a 70%, #0f3d1a 100%) !important;
    }
    .stat-number {
      background: linear-gradient(90deg, #3B82F6, #06B6D4, #84CC16) !important;
      -webkit-background-clip: text !important;
      -webkit-text-fill-color: transparent !important;
      background-clip: text !important;
    }
    .identity-box strong {
      background: linear-gradient(90deg, #3B82F6, #06B6D4, #84CC16);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
  </style>
</head>
<body>

